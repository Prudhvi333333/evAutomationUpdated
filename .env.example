# Required for Gemini runs and Gemini-based RAGAS evaluation
GEMINI_API_KEY=your_gemini_api_key

# Optional overrides
GEMINI_MODEL=gemini-2.5-flash
QWEN_MODEL=qwen2.5:14b
TINYLLAMA_MODEL=tinyllama
OLLAMA_BASE_URL=http://localhost:11434
RAGAS_JUDGE_PROVIDER=gemini
RAGAS_JUDGE_MODEL=gemini-2.5-flash
RAGAS_EMBEDDING_PROVIDER=google
RAGAS_EMBEDDING_MODEL=models/embedding-001
