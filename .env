# ══════════════════════════════════════════════════════════════════════════════
# EV LLM Comparison — Environment Configuration (Ollama / local mode)
# ══════════════════════════════════════════════════════════════════════════════
# No paid API keys needed for generation or evaluation.
# All models run locally via Ollama.
# ══════════════════════════════════════════════════════════════════════════════


# ── Experiment-level reproducibility ─────────────────────────────────────────
EXPERIMENT_SEED=42


# ── Ollama server ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434


# ── Generation Model 1: Qwen 2.5 14B (Ollama) ────────────────────────────────
# Pull before running: ollama pull qwen2.5:14b
# run_name: qwen14b_rag / qwen14b_no_rag
QWEN14B_MODEL=qwen2.5:14b

# ENABLE_QWEN14B_RAG=true
# ENABLE_QWEN14B_NO_RAG=true


# ── Generation Model 2: Qwen 2.5 32B (Ollama) ────────────────────────────────
# Pull before running: ollama pull qwen2.5:32b
# run_name: qwen32b_rag / qwen32b_no_rag
QWEN32B_MODEL=qwen2.5:32b

# ENABLE_QWEN32B_RAG=true
# ENABLE_QWEN32B_NO_RAG=true


# ── Generation Model 3: Qwen3 30B-A3B (Ollama) ───────────────────────────────
# Closest local equivalent to "Qwen3.5-35B-A3B".
# MoE model: 30B total params, only 3B active per token → fast despite size.
# Pull before running: ollama pull qwen3:30b-a3b
# run_name: qwen35b_rag / qwen35b_no_rag
QWEN35B_MODEL=qwen3:30b-a3b

# ENABLE_QWEN35B_RAG=true
# ENABLE_QWEN35B_NO_RAG=true


# ── Generation Model 3: Qwen Plus — DISABLED (cloud/API model only) ───────────
# "Qwen3.6-Plus" has no Ollama / open-weight release.
# If you want to use it via DashScope API, fill in the keys below and
# uncomment the ENABLE lines.
#
# QWEN36PLUS_MODEL=qwen-plus-latest
# QWEN36PLUS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN36PLUS_API_KEY_ENV=DASHSCOPE_API_KEY
# DASHSCOPE_API_KEY=your_dashscope_key_here
# ENABLE_QWEN36PLUS_RAG=true
# ENABLE_QWEN36PLUS_NO_RAG=true


# ── Evaluation / LLM-judge (Ollama — no API key needed) ──────────────────────
# Used ONLY during evaluation (not during generation with --skip-evaluation).
# qwen2.5:14b is already pulled for generation so it costs nothing extra.
# You can also use a larger model for better judge quality, e.g. qwen3:30b-a3b.
EVALUATION_JUDGE_PROVIDER=ollama
EVALUATION_JUDGE_MODEL=qwen2.5:14b

# Parallelism — keep at 1 for Ollama to avoid GPU contention
EVALUATION_PARALLELISM=1

# Disable RAGAS library (requires extra install + GPU memory)
RAGAS_ENABLED=false


# ── Optional models (disabled by default) ─────────────────────────────────────
# Gemma 27B — pull: ollama pull gemma3:27b
# GEMMA27B_MODEL=gemma3:27b
# ENABLE_GEMMA27B_RAG=true
# ENABLE_GEMMA27B_NO_RAG=true

# Gemini 2.5 Flash — requires a paid API key
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash
# ENABLE_GEMINI_FLASH_RAG=true
# ENABLE_GEMINI_FLASH_NO_RAG=true


# ── Shared generation parameters ──────────────────────────────────────────────
MODEL_TEMPERATURE=0.1
MODEL_MAX_TOKENS=2048


# ── Retrieval ──────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# QDRANT_PATH=artifacts/qdrant


# ── Legacy vars (kept for backward compatibility) ─────────────────────────────
QWEN_MODEL=qwen2.5:14b
GEMMA_MODEL=gemma3:27b
TINYLLAMA_MODEL=tinyllama
RAGAS_EMBEDDING_PROVIDER=huggingface
RAGAS_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
